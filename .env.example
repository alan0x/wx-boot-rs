# Database
DATABASE_URL=postgres://user:password@localhost:5432/wx_boot
DATABASE_CONNS=2

# Redis
REDIS_URL=redis://127.0.0.1:6379

# JWT & Security
SECRET_KEY=your-secret-key-change-me

# Super Admin Token (for admin API access without JWT)
SUPER_AUTH_TOKEN=your-super-auth-token-change-me

# Cookie
COOKIE_DOMAIN=localhost

# WeChat Mini-Program OAuth
WECHAT_MP_APPID=your-wechat-appid
WECHAT_MP_SECRET=your-wechat-secret

# WeChat Pay (微信支付)
WECHAT_APPID=your-wechat-appid          # 同小程序 AppID
WECHAT_MCH_ID=your-mch-id              # 微信支付商户号
WECHAT_PRIVATE_KEY=your-private-key    # API 私钥内容（apiclient_key.pem 的文本内容）
WECHAT_SERIAL_NO=your-serial-no        # 商户证书序列号
WECHAT_V3_KEY=your-v3-key             # APIv3 密钥（32字节）
WECHAT_NOTIFY_URL=https://yourdomain.com/orders/notify  # 支付结果回调地址（须公网可访问）

# File Storage
SPACE_PATH=/data/space

# Logging
LOG_LOCATION=/data/log_files

# Email (optional)
# TENCENT_SMTP_HOST=smtp.qcloudmail.com
# TENCENT_SMTP_SENDER=noreply@yourdomain.com
# TENCENT_SMTP_PORT=465
# TENCENT_SMTP_PASSWORD=your-smtp-password
